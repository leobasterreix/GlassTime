# Clé API TMDB (https://www.themoviedb.org/settings/api)
# Accepte la clé v3 ("api key") ou le jeton v4 ("API Read Access Token", commence par eyJ).
# Sans clé, l'application fonctionne avec un catalogue de démonstration.
# En local : copier ce fichier vers .env.local et renseigner la valeur.
# Sur Vercel : Settings → Environment Variables → TMDB_API_KEY.
TMDB_API_KEY=

# Mot de passe d'accès à l'application (usage privé).
# Sans cette variable, l'application est ouverte à tous.
# En local : .env.local · Sur Vercel : Settings → Environment Variables.
APP_PASSWORD=

# Synchronisation multi-appareils (optionnel) : base Redis créée via le
# marketplace Vercel (Upstash). Les variables sont ajoutées automatiquement
# par l'intégration ; rien à copier à la main sur Vercel.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Abonnement Premium (Lemon Squeezy) — nécessite un compte Lemon Squeezy avec
# un produit "GlassTime Premium" (variant récurrent) déjà créé.
# Buy-link hébergé du variant Premium (public, sans risque à exposer côté client).
NEXT_PUBLIC_LEMONSQUEEZY_BUY_URL=

# Secret de signature du webhook — Settings → Webhooks dans Lemon Squeezy.
# À configurer aussi côté Lemon Squeezy : URL du webhook =
# https://<domaine>/api/lemonsqueezy/webhook.
LEMONSQUEEZY_WEBHOOK_SECRET=

# Clé service-role Supabase — Settings → API dans le dashboard Supabase.
# Nécessaire pour que le webhook Lemon Squeezy puisse écrire le statut
# d'abonnement sans passer par les policies RLS utilisateur.
# NE JAMAIS exposer côté client (pas de préfixe NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=
